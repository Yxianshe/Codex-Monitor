<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:glass="using:LiquidGlassAvaloniaUI"
        xmlns:local="using:CodexMonitorV2"
        x:Class="CodexMonitorV2.MainWindow"
        x:CompileBindings="False"
        Title="Codex Monitor V2"
        Width="550" Height="460" MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None" CanResize="False"
        Background="Transparent" TransparencyLevelHint="Transparent"
        TextOptions.TextRenderingMode="Antialias"
        TextOptions.TextHintingMode="Strong"
        TextOptions.BaselinePixelAlignment="Aligned"
        ExtendClientAreaToDecorationsHint="True">
  <Window.Styles>
    <Style Selector="Button.top">
      <Setter Property="MinWidth" Value="34"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="5,0,0,0"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#72FFFFFF"/>
      <Setter Property="Background" Value="#24FFFFFF"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ClipToBounds="False">
            <glass:LiquidGlassSurface IsHitTestVisible="False"
                                      CornerRadius="16" RefractionHeight="12" Refraction="12"
                                      DepthEffect="True" Depth="1.05"
                                      ChromaticAberration="True" Dispersion="0.10"
                                      Frost="0.18" Splay="2.80" Light="1.15"
                                      BackdropOpacity="0.90" SurfaceColor="#06FFFFFF"
                                      HighlightEnabled="True" HighlightWidth="0.55"
                                      HighlightBlurRadius="0.45" HighlightOpacity="0.62"
                                      HighlightAngle="-42" HighlightFalloff="1.40"
                                      ShadowEnabled="True" ShadowRadius="6" ShadowOffset="1,3"
                                      ShadowColor="#50000000" ShadowOpacity="0.68"
                                      InnerShadowEnabled="True" InnerShadowRadius="5"
                                      InnerShadowOffset="-1,-2" InnerShadowColor="#30000000"
                                      InnerShadowOpacity="0.50"/>
            <Border CornerRadius="{TemplateBinding CornerRadius}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter Content="{TemplateBinding Content}"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.top:pointerover">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#42FFFFFF"/>
      <Setter Property="BorderBrush" Value="#D8FFFFFF"/>
    </Style>
    <Style Selector="Button.top:pressed">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#18FFFFFF"/>
      <Setter Property="BorderBrush" Value="#B8FFFFFF"/>
    </Style>
    <Style Selector="ProgressBar">
      <Setter Property="Height" Value="7"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#28B7C0CB"/>
    </Style>
    <Style Selector="ComboBox.taskChoice">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="Margin" Value="5,0,0,0"/>
      <Setter Property="CornerRadius" Value="13"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#48FFFFFF"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="FontSize" Value="11.5"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ComboBox.taskChoice:pointerover">
      <Setter Property="BorderBrush" Value="#B8FFFFFF"/>
    </Style>
    <Style Selector="ComboBox.taskChoice /template/ Border#PopupBorder">
      <Setter Property="Background" Value="#86121B2A"/>
      <Setter Property="BorderBrush" Value="#92FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="4"/>
    </Style>
    <Style Selector="ComboBox.taskChoice /template/ ScrollViewer">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ComboBoxItem">
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Padding" Value="9,5"/>
      <Setter Property="Margin" Value="3,2"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Background" Value="#2CFFFFFF"/>
      <Setter Property="Foreground" Value="#F4FFFFFF"/>
      <Setter Property="BorderBrush" Value="#38FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="#584E6A88"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="BorderBrush" Value="#72FFFFFF"/>
    </Style>
    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background" Value="#86518BC2"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="BorderBrush" Value="#A8C9E6FF"/>
    </Style>
    <Style Selector="ListBox#TaskList">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="CornerRadius" Value="13"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover">
      <Setter Property="Background" Value="#0CFFFFFF"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.taskRow">
      <Setter Property="Background" Value="#0EFFFFFF"/>
      <Setter Property="BorderBrush" Value="#46FFFFFF"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover Border.taskRow">
      <Setter Property="Background" Value="#18FFFFFF"/>
      <Setter Property="BorderBrush" Value="#72FFFFFF"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected Border.taskRow">
      <Setter Property="Background" Value="#30FFFFFF"/>
      <Setter Property="BorderBrush" Value="#A8FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="ScrollViewer#TaskScrollViewer /template/ ScrollBar:vertical">
      <Setter Property="Width" Value="7"/>
      <Setter Property="MinWidth" Value="7"/>
      <Setter Property="Margin" Value="0,5,2,5"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Opacity" Value="0.72"/>
      <Setter Property="AllowAutoHide" Value="False"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid Width="7" Background="Transparent">
            <Track Margin="1,0"
                   Minimum="{TemplateBinding Minimum}"
                   Maximum="{TemplateBinding Maximum}"
                   Value="{TemplateBinding Value, Mode=TwoWay}"
                   ViewportSize="{TemplateBinding ViewportSize}"
                   Orientation="{TemplateBinding Orientation}"
                   IsDirectionReversed="True">
              <Track.DecreaseButton>
                <RepeatButton Focusable="False" Background="Transparent">
                  <RepeatButton.Template>
                    <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.DecreaseButton>
              <Track.IncreaseButton>
                <RepeatButton Focusable="False" Background="Transparent">
                  <RepeatButton.Template>
                    <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.IncreaseButton>
              <Thumb Width="4" MinHeight="18" Background="#8098A1AE">
                <Thumb.Template>
                  <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                  </ControlTemplate>
                </Thumb.Template>
              </Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ScrollViewer#TaskScrollViewer /template/ ScrollBar:vertical:pointerover">
      <Setter Property="Opacity" Value="0.92"/>
    </Style>
    <Style Selector="ScrollViewer#TaskScrollViewer /template/ ScrollBar:vertical /template/ Thumb:pointerover">
      <Setter Property="Background" Value="#C0BCC5D0"/>
    </Style>
    <Style Selector="Button.settingAction">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="14,0"/>
      <Setter Property="CornerRadius" Value="17"/>
      <Setter Property="Background" Value="#20FFFFFF"/>
      <Setter Property="BorderBrush" Value="#58FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.settingAction:pointerover">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#36FFFFFF"/>
      <Setter Property="BorderBrush" Value="#A8FFFFFF"/>
    </Style>
    <Style Selector="Button.settingAction:pressed">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#24FFFFFF"/>
      <Setter Property="BorderBrush" Value="#D0FFFFFF"/>
    </Style>
    <Style Selector="Button.settingAction TextBlock">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.settingAction:pointerover TextBlock">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
    </Style>
    <Style Selector="Button.settingAction:pressed TextBlock">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
    </Style>
    <Style Selector="Slider.sceneSlider">
      <Setter Property="Height" Value="34"/>
      <Setter Property="ClipToBounds" Value="False"/>
      <Setter Property="Foreground" Value="#A7D9FF"/>
      <Setter Property="Background" Value="#28FFFFFF"/>
    </Style>
    <Style Selector="Slider.sceneSlider /template/ Thumb">
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Background" Value="#F8FFFFFF"/>
      <Setter Property="BorderBrush" Value="#E8FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="ClipToBounds" Value="False"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid Width="20" Height="20" ClipToBounds="False">
            <Border Width="20" Height="20" CornerRadius="10" Background="#2CFFFFFF"/>
            <Border Width="14" Height="14" CornerRadius="7"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"/>
            <Border Width="7" Height="3" CornerRadius="2" Margin="0,3,0,0"
                    VerticalAlignment="Top" Background="#B8FFFFFF"/>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Slider.sceneSlider /template/ Thumb:pointerover">
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
    </Style>
  </Window.Styles>

  <Grid Background="Transparent">
    <!-- DWM is the only outer clip. A second rounded mask creates visible corner wedges. -->
    <Border x:Name="WindowShape" Margin="0" CornerRadius="0" ClipToBounds="False"
            BorderThickness="0">
      <Grid>
        <local:SceneBackdrop x:Name="BackdropImage" Opacity="1"
                             RenderOptions.BitmapInterpolationMode="HighQuality"/>
        <glass:LiquidGlassSurface x:Name="GlassPanel"
                                  Opacity="1"
                                  CornerRadius="8"
                                  RefractionHeight="30"
                                  Refraction="25"
                                  DepthEffect="True"
                                  Depth="1.16"
                                  ChromaticAberration="True"
                                  Dispersion="0.16"
                                  Frost="0.22"
                                  Splay="2.90"
                                  Light="1.28"
                                  Vibrancy="1.04"
                                  Brightness="0.012"
                                  Contrast="1.04"
                                  BackdropOpacity="0.86"
                                  TintColor="#00000000"
                                  SurfaceColor="#06FFFFFF"
                                  HighlightEnabled="True"
                                  HighlightWidth="0.85"
                                  HighlightBlurRadius="0.65"
                                  HighlightOpacity="0.72"
                                  HighlightAngle="-42"
                                  HighlightFalloff="1.35"
                                  ShadowEnabled="False"
                                  InnerShadowEnabled="False"/>
      </Grid>
    </Border>
    <Border x:Name="ForegroundLayer" Margin="18" Background="#06020710" CornerRadius="18"
            glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="8">
        <Grid x:Name="TitleBar" ColumnDefinitions="*,Auto" Background="#01000000">
          <Grid ColumnDefinitions="34,*" RowDefinitions="Auto,Auto" ColumnSpacing="8">
            <Border Grid.RowSpan="2" Width="32" Height="32" CornerRadius="9"
                    Background="#16FFFFFF" BorderBrush="#EFFFFFFF" BorderThickness="2"
                    VerticalAlignment="Center">
              <Grid Width="26" Height="26">
                <Path Data="M19.8,8.2 C17.9,5.9 15.2,4.7 12.3,4.7 C7.2,4.7 3.3,8.6 3.3,13.2 C3.3,17.8 7.2,21.7 12.3,21.7 C16.7,21.7 20.2,18.9 21.1,15"
                      Stroke="#FFFFFFFF" StrokeThickness="3.1" StrokeLineCap="Round"
                      Fill="Transparent"/>
                <Ellipse Width="4.4" Height="4.4" Fill="#FFFFFFFF"
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         Margin="0,-1,1.2,0"/>
              </Grid>
            </Border>
            <TextBlock Grid.Column="1" Text="CODEX MONITOR" FontSize="10.5"
                       FontWeight="Bold" LetterSpacing="0.7" Foreground="#EFFFFFFF"/>
            <TextBlock x:Name="MainTitleText" Grid.Row="1" Grid.Column="1"
                       Text="Tasks &amp; Usage" FontSize="16.5" FontWeight="Bold"
                       Foreground="#FFFFFFFF" Margin="0,-1,0,0"/>
          </Grid>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Button x:Name="SettingsButton" Classes="top" Width="34" Padding="0">
              <PathIcon Width="17" Height="17" Foreground="#FFFFFFFF"
                        Data="M12,8.5 A3.5,3.5 0 1 0 12,15.5 A3.5,3.5 0 1 0 12,8.5 M19.43,12.98 C19.47,12.66 19.5,12.33 19.5,12 C19.5,11.67 19.47,11.34 19.42,11.02 L21.54,9.37 L19.54,5.91 L17.05,6.91 C16.54,6.5 15.97,6.17 15.35,5.92 L15,3.27 L11,3.27 L10.65,5.92 C10.03,6.17 9.46,6.5 8.95,6.91 L6.46,5.91 L4.46,9.37 L6.58,11.02 C6.53,11.34 6.5,11.67 6.5,12 C6.5,12.33 6.53,12.66 6.58,12.98 L4.46,14.63 L6.46,18.09 L8.95,17.09 C9.46,17.5 10.03,17.83 10.65,18.08 L11,20.73 L15,20.73 L15.35,18.08 C15.97,17.83 16.54,17.5 17.05,17.09 L19.54,18.09 L21.54,14.63 Z"/>
            </Button>
            <Button x:Name="TokenButton" Classes="top" Width="64">
              <TextBlock Text="Token" Foreground="#FFFFFFFF" FontWeight="SemiBold"/>
            </Button>
            <Button x:Name="ThemeButton" Classes="top" Width="34" Padding="0">
              <Grid Width="18" Height="18">
                <Ellipse Stroke="#DFFFFFFF" StrokeThickness="2"/>
                <Ellipse Width="7" Height="7" Fill="#9B8CFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                <Ellipse Width="7" Height="7" Fill="#58C7A7" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2"/>
              </Grid>
            </Button>
            <Button x:Name="LanguageButton" Classes="top" Width="40" Padding="0"
                    ToolTip.Tip="Switch to Chinese">
              <TextBlock x:Name="LanguageButtonText" Text="中" Foreground="#FFFFFFFF" FontWeight="SemiBold"/>
            </Button>
            <Button x:Name="PinButton" Classes="top" Width="34" Padding="0">
              <Grid Width="19" Height="19">
                <PathIcon x:Name="PinIdleIcon" Width="16" Height="16" Foreground="#FFFFFFFF"
                          Data="M16,12 L16,4 L17,4 L17,2 L7,2 L7,4 L8,4 L8,12 L6,14 L6,16 L11,16 L11,22 L13,22 L13,16 L18,16 L18,14 Z"/>
                <PathIcon x:Name="PinActiveIcon" Width="16" Height="16" Foreground="#D3AEFF" IsVisible="False"
                          RenderTransformOrigin="50%,50%"
                          Data="M16,12 L16,4 L17,4 L17,2 L7,2 L7,4 L8,4 L8,12 L6,14 L6,16 L11,16 L11,22 L13,22 L13,16 L18,16 L18,14 Z">
                  <PathIcon.RenderTransform><RotateTransform Angle="-38"/></PathIcon.RenderTransform>
                </PathIcon>
                <Ellipse x:Name="PinActiveDot" Width="5" Height="5" Fill="#C895FF" IsVisible="False"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
              </Grid>
            </Button>
            <Button x:Name="MinimizeButton" Classes="top" Width="34" Padding="0">
              <Border Width="13" Height="2" CornerRadius="1" Background="#FFFFFFFF"/>
            </Button>
            <Button x:Name="CloseButton" Classes="top" Width="34" Padding="0" Foreground="#FFFFFFFF" Background="#42B85F67">
              <PathIcon Width="13" Height="13" Foreground="#FFFFFFFF" Data="M2,1 L7,6 L12,1 L13,2 L8,7 L13,12 L12,13 L7,8 L2,13 L1,12 L6,7 L1,2 Z"/>
            </Button>
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="2,0">
          <TextBlock x:Name="ActiveTasksLabel" Text="Active tasks" FontSize="14.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          <StackPanel x:Name="DefaultSettingsPanel" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="4"
                      ToolTip.Tip="Set defaults for new Codex tasks; active turns remain unchanged">
            <TextBlock x:Name="DefaultLabel" Text="New" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFFFFFF" VerticalAlignment="Center"/>
            <ComboBox x:Name="DefaultModelBox" Classes="taskChoice" Width="120" Margin="0">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="7" Height="7" Fill="{Binding Accent}"/>
                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="DefaultEffortBox" Classes="taskChoice" Width="108" Margin="0">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <Ellipse Width="7" Height="7" Fill="{Binding Accent}"/>
                    <TextBlock Text="{Binding DisplayName}"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
          <TextBlock x:Name="StatusText" Grid.Column="2" MaxWidth="116" FontSize="11"
                     Foreground="#EAFFFFFF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="TaskCard" Grid.Row="2" MinHeight="92">
          <glass:LiquidGlassSurface x:Name="TaskLens" IsHitTestVisible="False"
                                    CornerRadius="18" RefractionHeight="22" Refraction="22"
                                    DepthEffect="True" Depth="1.08"
                                    ChromaticAberration="True" Dispersion="0.12"
                                    Frost="0.20" Splay="2.85" Light="1.18"
                                    Vibrancy="1.03" Brightness="0.008" Contrast="1.03"
                                    BackdropOpacity="0.90" SurfaceColor="#06FFFFFF"
                                    HighlightEnabled="True" HighlightWidth="0.75"
                                    HighlightBlurRadius="0.60" HighlightOpacity="0.68"
                                    HighlightAngle="-42" HighlightFalloff="1.40"
                                    ShadowEnabled="True" ShadowRadius="12" ShadowOffset="1,5"
                                    ShadowColor="#60000000" ShadowOpacity="0.78"
                                    InnerShadowEnabled="True" InnerShadowRadius="11"
                                    InnerShadowOffset="-1,-3" InnerShadowColor="#30000000"
                                    InnerShadowOpacity="0.58"/>
          <ScrollViewer x:Name="TaskScrollViewer" Margin="14,10"
                        VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ListBox x:Name="TaskList" ItemsSource="{Binding Tasks}">
              <ListBox.ItemContainerTheme>
                <ControlTheme TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="Margin" Value="0"/>
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                  <Setter Property="FocusAdorner" Value="{x:Null}"/>
                  <Setter Property="Template">
                    <ControlTemplate>
                      <ContentPresenter Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        Background="Transparent"
                                        HorizontalContentAlignment="Stretch"/>
                    </ControlTemplate>
                  </Setter>
                </ControlTheme>
              </ListBox.ItemContainerTheme>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="taskRow"
                          CornerRadius="13" Padding="10,7" Margin="1,1"
                          ToolTip.Tip="{Binding CurrentSummary}">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                      <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                 FontSize="13.5" Foreground="#FFFFFFFF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <Border Grid.Column="1" Grid.ColumnSpan="3" IsVisible="{Binding TokenVisible}"
                              Background="#22FFFFFF" BorderThickness="0" CornerRadius="12" Padding="9,4">
                        <TextBlock Text="{Binding TokenDetail}" FontSize="11.5" Foreground="#F4FFFFFF"/>
                      </Border>
                      <PathIcon Grid.Column="1"
                                IsVisible="{Binding PriorityVisible}"
                                Width="9" Height="13" Foreground="#C89CFF"
                                ToolTip.Tip="{Binding PriorityTip}"
                                Data="M7,0 L1,7 L5,7 L3,14 L11,5 L7,5 Z"/>
                      <Border Grid.Column="2" Width="112" Height="27"
                              IsVisible="{Binding SettingsVisible}" Background="{Binding ModelBackground}"
                              BorderBrush="#42FFFFFF" BorderThickness="1" CornerRadius="13" Padding="8,0">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="{Binding ModelAccent}"/>
                          <TextBlock Text="{Binding ModelDisplay}" Foreground="#FFFFFFFF" FontSize="11.5"
                                     TextTrimming="CharacterEllipsis" MaxWidth="78"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="3" Width="84" Height="27"
                              IsVisible="{Binding SettingsVisible}" Background="{Binding EffortBackground}"
                              BorderBrush="#42FFFFFF" BorderThickness="1" CornerRadius="13" Padding="8,0">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="{Binding EffortAccent}"/>
                          <TextBlock Text="{Binding EffortDisplay}" Foreground="#FFFFFFFF" FontSize="11.5"/>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="2,0">
          <TextBlock x:Name="UsageTitleText" Text="Usage" FontSize="15.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          <TextBlock x:Name="UpdatedText" Grid.Column="1" FontSize="10" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="UsageCard" Grid.Row="4">
          <glass:LiquidGlassSurface x:Name="UsageLens" IsHitTestVisible="False"
                                    CornerRadius="18" RefractionHeight="22" Refraction="22"
                                    DepthEffect="True" Depth="1.08"
                                    ChromaticAberration="True" Dispersion="0.12"
                                    Frost="0.20" Splay="2.85" Light="1.18"
                                    Vibrancy="1.03" Brightness="0.008" Contrast="1.03"
                                    BackdropOpacity="0.90" SurfaceColor="#06FFFFFF"
                                    HighlightEnabled="True" HighlightWidth="0.75"
                                    HighlightBlurRadius="0.60" HighlightOpacity="0.68"
                                    HighlightAngle="-42" HighlightFalloff="1.40"
                                    ShadowEnabled="True" ShadowRadius="12" ShadowOffset="1,5"
                                    ShadowColor="#60000000" ShadowOpacity="0.78"
                                    InnerShadowEnabled="True" InnerShadowRadius="11"
                                    InnerShadowOffset="-1,-3" InnerShadowColor="#30000000"
                                    InnerShadowOpacity="0.58"/>
          <Grid Margin="20,10" RowDefinitions="64,1,64">
            <Grid ColumnDefinitions="72,*,1,160">
              <StackPanel VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock x:Name="FiveTitleText" Text="5 hours" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                <TextBlock x:Name="FiveWindowText" Text="Limit window" FontSize="10.5" Foreground="#CCFFFFFF"/>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                  <TextBlock x:Name="FiveRemainingText" Text="Remaining" FontSize="12" Foreground="#F0FFFFFF"/>
                  <TextBlock x:Name="FiveQuotaValue" Grid.Column="1" Text="--%" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <ProgressBar x:Name="FiveQuotaBar" Maximum="100" Value="0" Foreground="#64A8FF"/>
                <TextBlock x:Name="FiveQuotaCaption" Text="Waiting for update" FontSize="10.5" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="2" Background="#38FFFFFF" Margin="0,10"/>
              <Border Grid.Column="3" Background="#14FFFFFF" BorderBrush="#3FFFFFFF"
                      BorderThickness="1" CornerRadius="16" Margin="10,2,0,2" Padding="7,3">
                <Grid ColumnDefinitions="54,*">
                <Grid Width="52" Height="52">
                  <local:RingGauge x:Name="FiveResetRing" Value="0" Track="#42D8DCE5" Stroke="#9B8CFF"/>
                  <TextBlock x:Name="FiveResetValue" Text="--" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                  <TextBlock x:Name="FiveResetTitleText" Text="Reset" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                  <TextBlock x:Name="FiveNextDateText" Text="Next date" FontSize="9.5" Foreground="#BFFFFFFF"/>
                  <TextBlock x:Name="FiveResetCaption" Text="--" FontSize="10.5" Foreground="#CCFFFFFF"/>
                </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <Border Grid.Row="1" Background="#5AFFFFFF" Margin="4,0"/>

            <Grid Grid.Row="2" ColumnDefinitions="72,*,1,160">
              <StackPanel VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock x:Name="WeekTitleText" Text="Weekly" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                <TextBlock x:Name="WeekWindowText" Text="Limit window" FontSize="10.5" Foreground="#CCFFFFFF"/>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                  <TextBlock x:Name="WeekRemainingText" Text="Remaining" FontSize="12" Foreground="#F0FFFFFF"/>
                  <TextBlock x:Name="WeekQuotaValue" Grid.Column="1" Text="--%" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <ProgressBar x:Name="WeekQuotaBar" Maximum="100" Value="0" Foreground="#58C7A7"/>
                <TextBlock x:Name="WeekQuotaCaption" Text="Waiting for update" FontSize="10.5" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="2" Background="#38FFFFFF" Margin="0,10"/>
              <Border Grid.Column="3" Background="#14FFFFFF" BorderBrush="#3FFFFFFF"
                      BorderThickness="1" CornerRadius="16" Margin="10,2,0,2" Padding="7,3">
                <Grid ColumnDefinitions="54,*">
                <Grid Width="52" Height="52">
                  <local:RingGauge x:Name="WeekResetRing" Value="0" Track="#42E2DDD7" Stroke="#EDAD60"/>
                  <TextBlock x:Name="WeekResetValue" Text="--" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                  <TextBlock x:Name="WeekResetTitleText" Text="Reset" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                  <TextBlock x:Name="WeekNextDateText" Text="Next date" FontSize="9.5" Foreground="#BFFFFFFF"/>
                  <TextBlock x:Name="WeekResetCaption" Text="--" FontSize="10.5" Foreground="#CCFFFFFF"/>
                </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Grid>
      </Border>

    <Grid x:Name="SceneSettingsOverlay" Margin="18" IsVisible="False"
          glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <glass:LiquidGlassSurface IsHitTestVisible="False"
                                CornerRadius="18" RefractionHeight="24" Refraction="22"
                                DepthEffect="True" Depth="1.10"
                                ChromaticAberration="True" Dispersion="0.10"
                                Frost="0.28" Splay="2.80" Light="1.18"
                                Vibrancy="1.02" Contrast="1.04" BackdropOpacity="0.92"
                                SurfaceColor="#18030A16" HighlightEnabled="True"
                                HighlightWidth="0.8" HighlightBlurRadius="0.7"
                                HighlightOpacity="0.68" HighlightAngle="-42"
                                HighlightFalloff="1.4" ShadowEnabled="False"/>
      <Border CornerRadius="18" Background="#50030A16" Padding="20">
        <Grid RowDefinitions="Auto,*" RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock x:Name="SceneSettingsTitleText" Text="Background settings"
                         FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
              <TextBlock x:Name="SceneSettingsSubtitleText" Text="Adjust the current scene without changing the window layout"
                         FontSize="10.5" Foreground="#C8FFFFFF"/>
            </StackPanel>
            <Button x:Name="SettingsCloseButton" Grid.Column="1" Classes="top" Width="34" Margin="8,0,0,0" Padding="0">
              <PathIcon Width="13" Height="13" Foreground="#FFFFFFFF"
                        Data="M2,1 L7,6 L12,1 L13,2 L8,7 L13,12 L12,13 L7,8 L2,13 L1,12 L6,7 L1,2 Z"/>
            </Button>
          </Grid>

          <StackPanel Grid.Row="1" Spacing="11">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
              <TextBlock x:Name="SceneSettingsSceneLabel" Text="Current scene" FontSize="12"
                         Foreground="#D8FFFFFF" VerticalAlignment="Center"/>
              <TextBlock x:Name="SceneSettingsSceneValue" Grid.Column="1" Text="Sun"
                         FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFFFF" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="7">
                <Button x:Name="ChooseSceneImageButton" Classes="settingAction">
                  <TextBlock x:Name="ChooseSceneImageText" Text="Choose image"/>
                </Button>
                <Button x:Name="ResetSceneImageButton" Classes="settingAction">
                  <TextBlock x:Name="ResetSceneImageText" Text="Restore default"/>
                </Button>
              </StackPanel>
            </Grid>
            <TextBlock x:Name="SceneImageNameText" Text="Built-in image" FontSize="10.5"
                       Foreground="#B8FFFFFF" TextTrimming="CharacterEllipsis"/>

            <Border Height="1" Background="#46FFFFFF"/>

            <Grid ColumnDefinitions="92,*,54" ColumnSpacing="12">
              <TextBlock x:Name="SceneZoomLabel" Text="Planet size" FontSize="12.5" Foreground="#F0FFFFFF" VerticalAlignment="Center"/>
              <Slider x:Name="SceneZoomSlider" Grid.Column="1" Classes="sceneSlider"
                      Minimum="1" Maximum="1.6" SmallChange="0.01" LargeChange="0.05"/>
              <TextBlock x:Name="SceneZoomValue" Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                         Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Grid ColumnDefinitions="92,*,54" ColumnSpacing="12">
              <TextBlock x:Name="ScenePositionXLabel" Text="Horizontal" FontSize="12.5" Foreground="#F0FFFFFF" VerticalAlignment="Center"/>
              <Slider x:Name="ScenePositionXSlider" Grid.Column="1" Classes="sceneSlider"
                      Minimum="-35" Maximum="35" SmallChange="1" LargeChange="5"/>
              <TextBlock x:Name="ScenePositionXValue" Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                         Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Grid ColumnDefinitions="92,*,54" ColumnSpacing="12">
              <TextBlock x:Name="ScenePositionYLabel" Text="Vertical" FontSize="12.5" Foreground="#F0FFFFFF" VerticalAlignment="Center"/>
              <Slider x:Name="ScenePositionYSlider" Grid.Column="1" Classes="sceneSlider"
                      Minimum="-28" Maximum="28" SmallChange="1" LargeChange="5"/>
              <TextBlock x:Name="ScenePositionYValue" Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                         Foreground="#FFFFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="SceneSettingsHintText"
                       Text="The image keeps its aspect ratio. Position values are relative to the app window."
                       FontSize="10.5" Foreground="#C0FFFFFF" TextWrapping="Wrap"/>
            <Button x:Name="SaveSceneSettingsButton" Classes="settingAction"
                    Width="128" HorizontalAlignment="Right">
              <TextBlock x:Name="SaveSceneSettingsText" Text="Save settings"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Grid glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <Border x:Name="MoveGrip" Width="190" Height="52" HorizontalAlignment="Left" VerticalAlignment="Top"
              Background="Transparent" Margin="10,0,0,0"/>
      <Border x:Name="TopGrip" Height="10" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNorthSouth"/>
      <Border x:Name="BottomGrip" Height="10" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth"/>
      <Border x:Name="LeftGrip" Width="10" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"/>
      <Border x:Name="RightGrip" Width="10" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast"/>
    </Grid>
  </Grid>
</Window>
