<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:glass="using:LiquidGlassAvaloniaUI"
        xmlns:local="using:CodexMonitorV2"
        x:Class="CodexMonitorV2.MainWindow"
        x:CompileBindings="False"
        Title="Codex Monitor V2"
        Width="550" Height="460" MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None" CanResize="True"
        Background="#081322"
        TextOptions.TextRenderingMode="Antialias"
        TextOptions.TextHintingMode="Strong"
        TextOptions.BaselinePixelAlignment="Aligned"
        ExtendClientAreaToDecorationsHint="True">
  <Window.Styles>
    <Style Selector="Button.top">
      <Setter Property="MinWidth" Value="34"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="5,0,0,0"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#72FFFFFF"/>
      <Setter Property="Background" Value="#24FFFFFF"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.top:pointerover">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#42FFFFFF"/>
      <Setter Property="BorderBrush" Value="#D8FFFFFF"/>
    </Style>
    <Style Selector="Button.top:pressed">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#18FFFFFF"/>
      <Setter Property="BorderBrush" Value="#B8FFFFFF"/>
    </Style>
    <Style Selector="ProgressBar">
      <Setter Property="Height" Value="7"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#28B7C0CB"/>
    </Style>
  </Window.Styles>

  <Grid Background="#081322">
    <Border Margin="0" CornerRadius="10" ClipToBounds="True"
            BorderThickness="0">
      <Image x:Name="BackdropImage" Stretch="Fill" Opacity="1"
             RenderTransformOrigin="0.5,0.5" RenderOptions.BitmapInterpolationMode="HighQuality">
        <Image.RenderTransform>
          <ScaleTransform ScaleX="1.06" ScaleY="1.02"/>
        </Image.RenderTransform>
      </Image>
    </Border>

    <glass:LiquidGlassSurface x:Name="GlassPanel"
                              Margin="6"
                              Opacity="1"
                              CornerRadius="16"
                              RefractionHeight="34"
                              RefractionAmount="32"
                              DepthEffect="True"
                              ChromaticAberration="True"
                              BlurRadius="0.35"
                              Vibrancy="1.22"
                              Brightness="0.02"
                              Contrast="1.16"
                              BackdropOpacity="1"
                              TintColor="#00000000"
                              SurfaceColor="#03FFFFFF"
                              HighlightEnabled="False"
                              ShadowEnabled="False"/>
    <Border Margin="16" Background="#12030910" CornerRadius="20"
            glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="8">
        <Grid x:Name="TitleBar" ColumnDefinitions="*,Auto" Background="#01000000">
          <StackPanel Spacing="1">
            <TextBlock Text="C O D E X   M O N I T O R" FontSize="9" FontWeight="SemiBold" Foreground="#D8FFFFFF"/>
            <TextBlock Text="任务与使用量" FontSize="21" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Button x:Name="TokenButton" Classes="top" Width="64">
              <TextBlock Text="Token" Foreground="#FFFFFFFF" FontWeight="SemiBold"/>
            </Button>
            <Button x:Name="ThemeButton" Classes="top" Width="34" Padding="0">
              <Grid Width="18" Height="18">
                <Ellipse Stroke="#DFFFFFFF" StrokeThickness="2"/>
                <Ellipse Width="7" Height="7" Fill="#9B8CFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                <Ellipse Width="7" Height="7" Fill="#58C7A7" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2"/>
              </Grid>
            </Button>
            <Button x:Name="PinButton" Classes="top" Width="34" Padding="0">
              <PathIcon Width="17" Height="17" Foreground="#FFFFFFFF"
                        Data="M16,12 L16,4 L17,4 L17,2 L7,2 L7,4 L8,4 L8,12 L6,14 L6,16 L11,16 L11,22 L13,22 L13,16 L18,16 L18,14 Z"/>
            </Button>
            <Button x:Name="MinimizeButton" Classes="top" Width="34" Padding="0">
              <Border Width="13" Height="2" CornerRadius="1" Background="#FFFFFFFF"/>
            </Button>
            <Button x:Name="CloseButton" Classes="top" Width="34" Padding="0" Foreground="#FFFFFFFF" Background="#42B85F67">
              <PathIcon Width="13" Height="13" Foreground="#FFFFFFFF" Data="M2,1 L7,6 L12,1 L13,2 L8,7 L13,12 L12,13 L7,8 L2,13 L1,12 L6,7 L1,2 Z"/>
            </Button>
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="2,0">
          <TextBlock Text="正在调用的任务" FontSize="14.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          <TextBlock x:Name="StatusText" Grid.Column="1" FontSize="12" Foreground="#EAFFFFFF"/>
        </Grid>

        <Grid x:Name="TaskCard" Grid.Row="2" MinHeight="92">
          <glass:LiquidGlassSurface IsHitTestVisible="False"
                                    CornerRadius="18" RefractionHeight="18" RefractionAmount="24"
                                    DepthEffect="True" ChromaticAberration="False" BlurRadius="0.65"
                                    Vibrancy="1.10" Brightness="0.02" Contrast="1.06"
                                    BackdropOpacity="0.96" SurfaceColor="#3A030A14"
                                    HighlightEnabled="False"
                                    ShadowEnabled="False"/>
          <ScrollViewer Margin="14,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Tasks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#16030914" BorderThickness="0"
                          CornerRadius="13" Padding="10,7" Margin="1,2">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                 FontSize="13.5" Foreground="#FFFFFFFF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <Border Grid.Column="1" Background="#22FFFFFF"
                              BorderThickness="0" CornerRadius="12" Padding="9,4">
                        <TextBlock Text="{Binding Detail}" FontSize="11.5" Foreground="#F4FFFFFF"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="2,0">
          <TextBlock Text="使用量概览" FontSize="15.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          <TextBlock x:Name="UpdatedText" Grid.Column="1" FontSize="10" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="UsageCard" Grid.Row="4">
          <glass:LiquidGlassSurface IsHitTestVisible="False"
                                    CornerRadius="18" RefractionHeight="18" RefractionAmount="24"
                                    DepthEffect="True" ChromaticAberration="False" BlurRadius="0.65"
                                    Vibrancy="1.10" Brightness="0.02" Contrast="1.06"
                                    BackdropOpacity="0.96" SurfaceColor="#3A030A14"
                                    HighlightEnabled="False"
                                    ShadowEnabled="False"/>
          <Grid Margin="20,10" RowDefinitions="64,1,64">
            <Grid ColumnDefinitions="72,*,1,145">
              <StackPanel VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock Text="5 小时" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                <TextBlock Text="限额周期" FontSize="10.5" Foreground="#CCFFFFFF"/>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                  <TextBlock Text="剩余额度" FontSize="12" Foreground="#F0FFFFFF"/>
                  <TextBlock x:Name="FiveQuotaValue" Grid.Column="1" Text="--%" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <ProgressBar x:Name="FiveQuotaBar" Maximum="100" Value="0" Foreground="#64A8FF"/>
                <TextBlock x:Name="FiveQuotaCaption" Text="等待更新" FontSize="10.5" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="2" Background="#38FFFFFF" Margin="0,10"/>
              <Grid Grid.Column="3" ColumnDefinitions="62,*" Margin="12,0,0,0">
                <Grid Width="62" Height="62">
                  <local:RingGauge x:Name="FiveResetRing" Value="0" Track="#42D8DCE5" Stroke="#9B8CFF"/>
                  <TextBlock x:Name="FiveResetValue" Text="--" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                  <TextBlock Text="重置" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                  <TextBlock Text="剩余时间" FontSize="10.5" Foreground="#CCFFFFFF"/>
                  <TextBlock x:Name="FiveResetCaption" Text="--" FontSize="10.5" Foreground="#CCFFFFFF"/>
                </StackPanel>
              </Grid>
            </Grid>

            <Border Grid.Row="1" Background="#28FFFFFF" Margin="4,0"/>

            <Grid Grid.Row="2" ColumnDefinitions="72,*,1,145">
              <StackPanel VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock Text="每周" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                <TextBlock Text="限额周期" FontSize="10.5" Foreground="#CCFFFFFF"/>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                  <TextBlock Text="剩余额度" FontSize="12" Foreground="#F0FFFFFF"/>
                  <TextBlock x:Name="WeekQuotaValue" Grid.Column="1" Text="--%" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <ProgressBar x:Name="WeekQuotaBar" Maximum="100" Value="0" Foreground="#58C7A7"/>
                <TextBlock x:Name="WeekQuotaCaption" Text="等待更新" FontSize="10.5" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="2" Background="#38FFFFFF" Margin="0,10"/>
              <Grid Grid.Column="3" ColumnDefinitions="62,*" Margin="12,0,0,0">
                <Grid Width="62" Height="62">
                  <local:RingGauge x:Name="WeekResetRing" Value="0" Track="#42E2DDD7" Stroke="#EDAD60"/>
                  <TextBlock x:Name="WeekResetValue" Text="--" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                  <TextBlock Text="重置" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                  <TextBlock Text="剩余时间" FontSize="10.5" Foreground="#CCFFFFFF"/>
                  <TextBlock x:Name="WeekResetCaption" Text="--" FontSize="10.5" Foreground="#CCFFFFFF"/>
                </StackPanel>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Grid>
      </Border>

    <Grid glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <Border x:Name="MoveGrip" Width="300" Height="82" HorizontalAlignment="Left" VerticalAlignment="Top"
              Background="#01000000" Margin="10,0,0,0"/>
      <Border x:Name="TopGrip" Height="10" VerticalAlignment="Top" Background="#01000000" Margin="18,0" Cursor="SizeNorthSouth"/>
      <Border x:Name="BottomGrip" Height="10" VerticalAlignment="Bottom" Background="#01000000" Margin="18,0" Cursor="SizeNorthSouth"/>
      <Border x:Name="LeftGrip" Width="10" HorizontalAlignment="Left" Background="#01000000" Margin="0,18" Cursor="SizeWestEast"/>
      <Border x:Name="RightGrip" Width="10" HorizontalAlignment="Right" Background="#01000000" Margin="0,18" Cursor="SizeWestEast"/>
      <Border x:Name="TopLeftGrip" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#01000000" Cursor="TopLeftCorner"/>
      <Border x:Name="TopRightGrip" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#01000000" Cursor="TopRightCorner"/>
      <Border x:Name="BottomLeftGrip" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="#01000000" Cursor="TopRightCorner"/>
      <Border x:Name="BottomRightGrip" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#01000000" Cursor="TopLeftCorner"/>
    </Grid>
  </Grid>
</Window>
