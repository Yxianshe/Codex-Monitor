<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:glass="using:LiquidGlassAvaloniaUI"
        xmlns:local="using:CodexMonitorV2"
        x:Class="CodexMonitorV2.MainWindow"
        x:CompileBindings="False"
        Title="Codex Monitor V2"
        Width="550" Height="460" MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None" CanResize="True"
        Background="Transparent" TransparencyLevelHint="Transparent"
        TextOptions.TextRenderingMode="Antialias"
        TextOptions.TextHintingMode="Strong"
        TextOptions.BaselinePixelAlignment="Aligned"
        ExtendClientAreaToDecorationsHint="True">
  <Window.Styles>
    <Style Selector="Button.top">
      <Setter Property="MinWidth" Value="34"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="5,0,0,0"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#72FFFFFF"/>
      <Setter Property="Background" Value="#24FFFFFF"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ClipToBounds="False">
            <glass:LiquidGlassSurface IsHitTestVisible="False"
                                      CornerRadius="16" RefractionHeight="10" Refraction="9"
                                      DepthEffect="True" Depth="0.78"
                                      ChromaticAberration="True" Dispersion="0.48"
                                      Frost="0.35" Splay="2.2" Light="0.92"
                                      BackdropOpacity="0.98" SurfaceColor="#0DFFFFFF"
                                      HighlightEnabled="False" ShadowEnabled="False"/>
            <Border CornerRadius="{TemplateBinding CornerRadius}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter Content="{TemplateBinding Content}"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.top:pointerover">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#42FFFFFF"/>
      <Setter Property="BorderBrush" Value="#D8FFFFFF"/>
    </Style>
    <Style Selector="Button.top:pressed">
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="Background" Value="#18FFFFFF"/>
      <Setter Property="BorderBrush" Value="#B8FFFFFF"/>
    </Style>
    <Style Selector="ProgressBar">
      <Setter Property="Height" Value="7"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#28B7C0CB"/>
    </Style>
    <Style Selector="ComboBox.taskChoice">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="Margin" Value="5,0,0,0"/>
      <Setter Property="CornerRadius" Value="13"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#48FFFFFF"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="FontSize" Value="11.5"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ComboBox.taskChoice:pointerover">
      <Setter Property="BorderBrush" Value="#B8FFFFFF"/>
    </Style>
    <Style Selector="ComboBoxItem">
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Padding" Value="9,5"/>
      <Setter Property="Background" Value="#F4F6F8FC"/>
      <Setter Property="Foreground" Value="#FF172033"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="#FFE4EBF7"/>
      <Setter Property="Foreground" Value="#FF101827"/>
    </Style>
    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background" Value="#FFD7E4F8"/>
      <Setter Property="Foreground" Value="#FF101827"/>
    </Style>
    <Style Selector="ListBox#TaskList">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="CornerRadius" Value="13"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover">
      <Setter Property="Background" Value="#0CFFFFFF"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.taskRow">
      <Setter Property="Background" Value="#0EFFFFFF"/>
      <Setter Property="BorderBrush" Value="#46FFFFFF"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover Border.taskRow">
      <Setter Property="Background" Value="#18FFFFFF"/>
      <Setter Property="BorderBrush" Value="#72FFFFFF"/>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected Border.taskRow">
      <Setter Property="Background" Value="#30FFFFFF"/>
      <Setter Property="BorderBrush" Value="#A8FFFFFF"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
  </Window.Styles>

  <Grid Background="Transparent">
    <Border Margin="0" CornerRadius="14" ClipToBounds="True"
            BorderThickness="0">
      <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="1"
             RenderOptions.BitmapInterpolationMode="HighQuality"/>
    </Border>

    <glass:LiquidGlassSurface x:Name="GlassPanel"
                              Margin="2"
                              Opacity="1"
                              CornerRadius="22"
                              RefractionHeight="20"
                              Refraction="16"
                              DepthEffect="True"
                              Depth="0.90"
                              ChromaticAberration="True"
                              Dispersion="0.55"
                              Frost="0.55"
                              Splay="2.40"
                              Light="1.02"
                              Vibrancy="1.16"
                              Brightness="0.035"
                              Contrast="1.11"
                              BackdropOpacity="1"
                              TintColor="#00000000"
                              SurfaceColor="#07FFFFFF"
                              HighlightEnabled="True"
                              HighlightWidth="0.7"
                              HighlightBlurRadius="0.7"
                              HighlightOpacity="0.52"
                              HighlightAngle="-38"
                              HighlightFalloff="0.72"
                              ShadowEnabled="False"/>
    <Border x:Name="ForegroundLayer" Margin="18" Background="#06020710" CornerRadius="20"
            glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="8">
        <Grid x:Name="TitleBar" ColumnDefinitions="*,Auto" Background="#01000000">
          <StackPanel Spacing="1">
            <TextBlock Text="C O D E X   M O N I T O R" FontSize="9" FontWeight="SemiBold" Foreground="#D8FFFFFF"/>
            <TextBlock x:Name="MainTitleText" Text="Tasks &amp; Usage" FontSize="21" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Button x:Name="TokenButton" Classes="top" Width="64">
              <TextBlock Text="Token" Foreground="#FFFFFFFF" FontWeight="SemiBold"/>
            </Button>
            <Button x:Name="ThemeButton" Classes="top" Width="34" Padding="0">
              <Grid Width="18" Height="18">
                <Ellipse Stroke="#DFFFFFFF" StrokeThickness="2"/>
                <Ellipse Width="7" Height="7" Fill="#9B8CFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                <Ellipse Width="7" Height="7" Fill="#58C7A7" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2"/>
              </Grid>
            </Button>
            <Button x:Name="LanguageButton" Classes="top" Width="40" Padding="0"
                    ToolTip.Tip="Switch to Chinese">
              <TextBlock x:Name="LanguageButtonText" Text="中" Foreground="#FFFFFFFF" FontWeight="SemiBold"/>
            </Button>
            <Button x:Name="PinButton" Classes="top" Width="34" Padding="0">
              <PathIcon Width="17" Height="17" Foreground="#FFFFFFFF"
                        Data="M16,12 L16,4 L17,4 L17,2 L7,2 L7,4 L8,4 L8,12 L6,14 L6,16 L11,16 L11,22 L13,22 L13,16 L18,16 L18,14 Z"/>
            </Button>
            <Button x:Name="MinimizeButton" Classes="top" Width="34" Padding="0">
              <Border Width="13" Height="2" CornerRadius="1" Background="#FFFFFFFF"/>
            </Button>
            <Button x:Name="CloseButton" Classes="top" Width="34" Padding="0" Foreground="#FFFFFFFF" Background="#42B85F67">
              <PathIcon Width="13" Height="13" Foreground="#FFFFFFFF" Data="M2,1 L7,6 L12,1 L13,2 L8,7 L13,12 L12,13 L7,8 L2,13 L1,12 L6,7 L1,2 Z"/>
            </Button>
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="2,0">
          <TextBlock x:Name="ActiveTasksLabel" Text="Active tasks" FontSize="14.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          <StackPanel x:Name="DefaultSettingsPanel" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="4"
                      ToolTip.Tip="Set defaults for new Codex tasks; active turns remain unchanged">
            <TextBlock x:Name="DefaultLabel" Text="New" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFFFFFF" VerticalAlignment="Center"/>
            <ComboBox x:Name="DefaultModelBox" Classes="taskChoice" Width="120" Margin="0">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="7" Height="7" Fill="{Binding Accent}"/>
                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox x:Name="DefaultEffortBox" Classes="taskChoice" Width="108" Margin="0">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <Ellipse Width="7" Height="7" Fill="{Binding Accent}"/>
                    <TextBlock Text="{Binding DisplayName}"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
          <TextBlock x:Name="StatusText" Grid.Column="2" MaxWidth="116" FontSize="11"
                     Foreground="#EAFFFFFF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="TaskCard" Grid.Row="2" MinHeight="92">
          <glass:LiquidGlassSurface x:Name="TaskLens" IsHitTestVisible="False"
                                    CornerRadius="18" RefractionHeight="18" Refraction="16"
                                    DepthEffect="True" Depth="0.82"
                                    ChromaticAberration="True" Dispersion="0.42"
                                    Frost="0.48" Splay="2.15" Light="0.78"
                                    Vibrancy="1.08" Brightness="0.02" Contrast="1.05"
                                    BackdropOpacity="0.98" SurfaceColor="#10020A18"
                                    HighlightEnabled="True" HighlightWidth="0.45"
                                    HighlightBlurRadius="0.55" HighlightOpacity="0.28"
                                    ShadowEnabled="False"/>
          <ScrollViewer Margin="14,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ListBox x:Name="TaskList" ItemsSource="{Binding Tasks}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="taskRow"
                          CornerRadius="13" Padding="10,7" Margin="1,1"
                          ToolTip.Tip="{Binding CurrentSummary}">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                      <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                 FontSize="13.5" Foreground="#FFFFFFFF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <Border Grid.Column="1" Grid.ColumnSpan="3" IsVisible="{Binding TokenVisible}"
                              Background="#22FFFFFF" BorderThickness="0" CornerRadius="12" Padding="9,4">
                        <TextBlock Text="{Binding TokenDetail}" FontSize="11.5" Foreground="#F4FFFFFF"/>
                      </Border>
                      <TextBlock Grid.Column="1" IsVisible="{Binding SettingsVisible}" Text="{Binding CurrentLabel}"
                                 FontSize="9.5" Foreground="#C8FFFFFF" VerticalAlignment="Center"/>
                      <Border Grid.Column="2" Width="112" Height="27"
                              IsVisible="{Binding SettingsVisible}" Background="{Binding ModelBackground}"
                              BorderBrush="#42FFFFFF" BorderThickness="1" CornerRadius="13" Padding="8,0">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="{Binding ModelAccent}"/>
                          <TextBlock Text="{Binding ModelDisplay}" Foreground="#FFFFFFFF" FontSize="11.5"
                                     TextTrimming="CharacterEllipsis" MaxWidth="78"/>
                        </StackPanel>
                      </Border>
                      <Border Grid.Column="3" Width="84" Height="27"
                              IsVisible="{Binding SettingsVisible}" Background="{Binding EffortBackground}"
                              BorderBrush="#42FFFFFF" BorderThickness="1" CornerRadius="13" Padding="8,0">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="{Binding EffortAccent}"/>
                          <TextBlock Text="{Binding EffortDisplay}" Foreground="#FFFFFFFF" FontSize="11.5"/>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="2,0">
          <TextBlock x:Name="UsageTitleText" Text="Usage" FontSize="15.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
          <TextBlock x:Name="UpdatedText" Grid.Column="1" FontSize="10" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="UsageCard" Grid.Row="4">
          <glass:LiquidGlassSurface x:Name="UsageLens" IsHitTestVisible="False"
                                    CornerRadius="18" RefractionHeight="18" Refraction="16"
                                    DepthEffect="True" Depth="0.82"
                                    ChromaticAberration="True" Dispersion="0.42"
                                    Frost="0.48" Splay="2.15" Light="0.78"
                                    Vibrancy="1.08" Brightness="0.02" Contrast="1.05"
                                    BackdropOpacity="0.98" SurfaceColor="#10020A18"
                                    HighlightEnabled="True" HighlightWidth="0.45"
                                    HighlightBlurRadius="0.55" HighlightOpacity="0.28"
                                    ShadowEnabled="False"/>
          <Grid Margin="20,10" RowDefinitions="64,1,64">
            <Grid ColumnDefinitions="72,*,1,160">
              <StackPanel VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock x:Name="FiveTitleText" Text="5 hours" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                <TextBlock x:Name="FiveWindowText" Text="Limit window" FontSize="10.5" Foreground="#CCFFFFFF"/>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                  <TextBlock x:Name="FiveRemainingText" Text="Remaining" FontSize="12" Foreground="#F0FFFFFF"/>
                  <TextBlock x:Name="FiveQuotaValue" Grid.Column="1" Text="--%" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <ProgressBar x:Name="FiveQuotaBar" Maximum="100" Value="0" Foreground="#64A8FF"/>
                <TextBlock x:Name="FiveQuotaCaption" Text="Waiting for update" FontSize="10.5" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="2" Background="#38FFFFFF" Margin="0,10"/>
              <Border Grid.Column="3" Background="#14FFFFFF" BorderBrush="#3FFFFFFF"
                      BorderThickness="1" CornerRadius="16" Margin="10,2,0,2" Padding="7,3">
                <Grid ColumnDefinitions="54,*">
                <Grid Width="52" Height="52">
                  <local:RingGauge x:Name="FiveResetRing" Value="0" Track="#42D8DCE5" Stroke="#9B8CFF"/>
                  <TextBlock x:Name="FiveResetValue" Text="--" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                  <TextBlock x:Name="FiveResetTitleText" Text="Reset" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                  <TextBlock x:Name="FiveNextDateText" Text="Next date" FontSize="9.5" Foreground="#BFFFFFFF"/>
                  <TextBlock x:Name="FiveResetCaption" Text="--" FontSize="10.5" Foreground="#CCFFFFFF"/>
                </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <Border Grid.Row="1" Background="#5AFFFFFF" Margin="4,0"/>

            <Grid Grid.Row="2" ColumnDefinitions="72,*,1,160">
              <StackPanel VerticalAlignment="Center" Margin="2,0,8,0">
                <TextBlock x:Name="WeekTitleText" Text="Weekly" FontSize="13.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                <TextBlock x:Name="WeekWindowText" Text="Limit window" FontSize="10.5" Foreground="#CCFFFFFF"/>
              </StackPanel>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                  <TextBlock x:Name="WeekRemainingText" Text="Remaining" FontSize="12" Foreground="#F0FFFFFF"/>
                  <TextBlock x:Name="WeekQuotaValue" Grid.Column="1" Text="--%" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <ProgressBar x:Name="WeekQuotaBar" Maximum="100" Value="0" Foreground="#58C7A7"/>
                <TextBlock x:Name="WeekQuotaCaption" Text="Waiting for update" FontSize="10.5" Foreground="#CCFFFFFF" Margin="0,4,0,0"/>
              </StackPanel>
              <Border Grid.Column="2" Background="#38FFFFFF" Margin="0,10"/>
              <Border Grid.Column="3" Background="#14FFFFFF" BorderBrush="#3FFFFFFF"
                      BorderThickness="1" CornerRadius="16" Margin="10,2,0,2" Padding="7,3">
                <Grid ColumnDefinitions="54,*">
                <Grid Width="52" Height="52">
                  <local:RingGauge x:Name="WeekResetRing" Value="0" Track="#42E2DDD7" Stroke="#EDAD60"/>
                  <TextBlock x:Name="WeekResetValue" Text="--" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                  <TextBlock x:Name="WeekResetTitleText" Text="Reset" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFFFF"/>
                  <TextBlock x:Name="WeekNextDateText" Text="Next date" FontSize="9.5" Foreground="#BFFFFFFF"/>
                  <TextBlock x:Name="WeekResetCaption" Text="--" FontSize="10.5" Foreground="#CCFFFFFF"/>
                </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Grid>
      </Border>

    <Grid glass:LiquidGlassBackdrop.IsExcludedFromCapture="True">
      <Border x:Name="MoveGrip" Width="240" Height="52" HorizontalAlignment="Left" VerticalAlignment="Top"
              Background="#01000000" Margin="10,0,0,0"/>
      <Border x:Name="TopGrip" Height="10" VerticalAlignment="Top" Background="#01000000" Margin="18,0" Cursor="SizeNorthSouth"/>
      <Border x:Name="BottomGrip" Height="10" VerticalAlignment="Bottom" Background="#01000000" Margin="18,0" Cursor="SizeNorthSouth"/>
      <Border x:Name="LeftGrip" Width="10" HorizontalAlignment="Left" Background="#01000000" Margin="0,18" Cursor="SizeWestEast"/>
      <Border x:Name="RightGrip" Width="10" HorizontalAlignment="Right" Background="#01000000" Margin="0,18" Cursor="SizeWestEast"/>
      <Border x:Name="TopLeftGrip" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#01000000" Cursor="TopLeftCorner"/>
      <Border x:Name="TopRightGrip" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#01000000" Cursor="TopRightCorner"/>
      <Border x:Name="BottomLeftGrip" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="#01000000" Cursor="TopRightCorner"/>
      <Border x:Name="BottomRightGrip" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#01000000" Cursor="TopLeftCorner"/>
    </Grid>
  </Grid>
</Window>
