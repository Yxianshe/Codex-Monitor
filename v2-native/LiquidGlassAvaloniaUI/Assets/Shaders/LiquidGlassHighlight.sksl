// Liquid Glass Highlight Shader
// Adapted for SKRuntimeEffect.

uniform float2 size;
uniform float4 cornerRadii; // [topLeft, topRight, bottomRight, bottomLeft]
uniform float4 color;       // RGBA (0..1)
uniform float angle;        // radians
uniform float falloff;      // >= 0
uniform float flowPhase;    // normalized 0..1, loops forever

const float TWO_PI = 6.28318530718;

float radiusAt(float2 centeredCoord, float4 radii) {
    if (centeredCoord.x >= 0.0) {
        if (centeredCoord.y < 0.0) return radii.y;
        else return radii.z;
    } else {
        if (centeredCoord.y < 0.0) return radii.x;
        else return radii.w;
    }
}

float sdRoundedRect(float2 coord, float2 halfSize, float radius) {
    float2 cornerCoord = abs(coord) - (halfSize - float2(radius));
    float outside = length(max(cornerCoord, 0.0)) - radius;
    float inside = min(max(cornerCoord.x, cornerCoord.y), 0.0);
    return outside + inside;
}

float2 gradSdRoundedRect(float2 coord, float2 halfSize, float radius) {
    float2 cornerCoord = abs(coord) - (halfSize - float2(radius));
    if (cornerCoord.x >= 0.0 || cornerCoord.y >= 0.0) {
        return sign(coord) * normalize(max(cornerCoord, 0.0));
    } else {
        float gradX = step(cornerCoord.y, cornerCoord.x);
        return sign(coord) * float2(gradX, 1.0 - gradX);
    }
}

half4 main(float2 coord) {
    float2 halfSize = size * 0.5;
    float2 centeredCoord = coord - halfSize;
    float radius = radiusAt(centeredCoord, cornerRadii);

    // Compute the "surface normal" using SDF gradient.
    float gradRadius = min(radius * 1.5, min(halfSize.x, halfSize.y));
    float2 grad = gradSdRoundedRect(centeredCoord, halfSize, gradRadius);
    float2 normal = float2(cos(angle), sin(angle));

    float d = dot(grad, normal);
    float intensity = pow(abs(d), max(falloff, 0.0));

    // A low-saturation pearl spectrum travels around the single physical rim.
    float perimeter = atan(centeredCoord.y, centeredCoord.x) / TWO_PI + 0.5;
    float travel = fract(perimeter - flowPhase);
    float pearl = 0.5 + 0.5 * cos(TWO_PI * travel);
    float3 cyan = float3(0.62, 0.91, 1.0);
    float3 violet = float3(0.78, 0.68, 1.0);
    float3 warm = float3(1.0, 0.94, 0.78);
    float3 spectrum = mix(cyan, violet, smoothstep(0.0, 0.55, pearl));
    spectrum = mix(spectrum, warm, smoothstep(0.68, 1.0, pearl));
    float3 pearlColor = mix(color.rgb, spectrum, 0.48);

    // Keep the static rim faint and let one narrow pearl highlight travel forever.
    float movingHighlight = pow(clamp(pearl, 0.0, 1.0), 8.0);
    half a = half(color.a * (0.08 + intensity * 0.20 + movingHighlight * 0.72));
    half3 rgb = half3(pearlColor) * a;
    return half4(rgb, a);
}
